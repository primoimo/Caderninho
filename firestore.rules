rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidMeeting(data) {
      return hasOnlyAllowedFields(['title', 'description', 'theme', 'faithLevel', 'duration', 'peopleCount', 'steps', 'createdAt', 'userId', 'authorName']) &&
             hasRequiredFields(['title', 'description', 'theme', 'faithLevel', 'duration', 'peopleCount', 'steps']) &&
             validStringLength('title', 1, 100) &&
             validStringLength('description', 0, 500) &&
             validStringLength('theme', 0, 50) &&
             validStringLength('faithLevel', 0, 50) &&
             validStringLength('duration', 0, 50) &&
             data.peopleCount is number && data.peopleCount >= 0 &&
             data.steps is list && data.steps.size() <= 20 &&
             (!('createdAt' in data) || data.createdAt is string) &&
             (!('userId' in data) || data.userId is string) &&
             (!('authorName' in data) || data.authorName is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /meetings/{meetingId} {
      allow read: if true;
      allow create: if isValidMeeting(request.resource.data);
      allow update: if isValidMeeting(request.resource.data) &&
                    (!('createdAt' in request.resource.data) || !('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt); // Immutable
      allow delete: if true;
    }
  }
}
